{
  "name": "wall-clock-card",
  "version": "3.0.0",
  "description": "A customizable Home Assistant wall dashboard with zone-based clock, sensor, weather, calendar, transport, and action widgets",
  "main": "dist/wall-clock-card.js",
  "scripts": {
    "build": "webpack",
    "watch": "webpack --watch --mode=development",
    "update-card-tools": "npm uninstall card-tools && npm install thomasloven/lovelace-card-tools",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "analyze": "webpack --analyze",
    "deploy": "node scripts/deploy.js",
    "bump": "node scripts/bump-resource.js"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "clock",
    "card",
    "custom-card",
    "dashboard",
    "weather",
    "calendar"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "lit": "^3.3.0",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@types/sortablejs": "^1.15.9",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.5",
    "webpack": "^5.70.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^4.9.2"
  }
}
